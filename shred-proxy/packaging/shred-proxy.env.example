# Configuration for shred-proxy, read by the systemd unit as /etc/default/shred-proxy.
#
# Every setting is OPTIONAL: anything left unset (or commented out) falls back to the binary's
# built-in default. Each variable maps 1:1 to a CLI flag — run `shred-proxy --help` for details.
# After editing, apply with:  sudo systemctl restart shred-proxy

# Local UDP destination(s) every deduplicated shred is forwarded to (comma-separated host:port).
# This is what your local consumer (e.g. Jito shredstream-proxy) listens on.
#DZ_FORWARD=127.0.0.1:8001

# DoubleZero interface to join multicast on; also the interface name matched during routing-table
# active-group detection.
#DZ_IFACE=doublezero1

# Candidate multicast groups probed in the routing table (comma-separated). The proxy joins only
# those the kernel routes via DZ_IFACE.
#DZ_CANDIDATE_GROUPS=233.84.178.1,233.84.178.16,233.84.178.14,233.84.178.13,233.84.178.12

# UDP port shared by all groups.
#DZ_PORT=7733

# Deduplication mode: `dedup` (default, forward one copy of each shred) or `none` (forward every
# datagram, duplicates included).
#DZ_DEDUP_MODE=dedup

# Per-socket kernel receive buffer (SO_RCVBUF) in bytes. To actually get more than a few hundred KiB
# the kernel needs net.core.rmem_max raised to at least this value — see 60-shred-proxy.conf.
#DZ_RECV_BUF=8388608

# Dedup window depth in slots (bounds memory).
#DZ_DEDUP_WINDOW_SLOTS=512

# Routing-table re-probe interval in seconds.
#DZ_REFRESH_SECS=30

# Log verbosity (tracing EnvFilter syntax). Quiet base with both this crate AND the shared forwarder
# library at info — the actual forwarding/dedup/group-join logs come from `doublezero_edge_connect`
# (the reused library target), so omitting it would silence them. Matches the binary's built-in
# default.
RUST_LOG=warn,shred_proxy=info,doublezero_edge_connect=info
